---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const { id } = Astro.params;
let perf: any = {};

try {
  const response = await fetch(`http://localhost:3001/api/performance/performance-detail/${id}`);
  if (response.ok) {
    perf = await response.json();
    console.log("Loaded data:", perf);
  }
} catch (error) {
  console.error("Error fetching performance:", error);
}
---

<Layout>
  <div class="max-w-5xl mx-auto p-6 bg-gray-50 min-h-screen">
    <a href="/" class="text-blue-600 mb-4 inline-block font-bold hover:underline">&larr; Back to Performances</a>
    <h1 class="text-3xl font-bold mb-6">Edit Performance</h1>

    <!-- Player Header -->
    <div class="bg-white p-6 rounded-xl shadow-sm mb-6 flex items-center justify-between border border-gray-200">
      <div class="flex items-center">
        <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-xl mr-4">
          {perf.player_name ? perf.player_name.substring(0, 2).toUpperCase() : '??'}
        </div>
        <div>
          <h2 class="text-2xl font-bold">{perf.player_name || 'Unknown Player'}</h2>
          <p class="text-gray-500">#{perf.jersey_number || '0'} | {perf.position || 'N/A'}</p>
        </div>
      </div>
      <div class="text-right text-sm">
        <p><strong>Match:</strong> {perf.team || 'N/A'} vs {perf.opponent_team || 'N/A'}</p>
        <p><strong>Date:</strong> {perf.match_date ? new Date(perf.match_date).toLocaleDateString() : 'N/A'}</p>
      </div>
    </div>

    <form id="editForm" class="grid grid-cols-2 gap-6">
      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
        <h3 class="font-bold mb-4 text-blue-600 border-b pb-2">Attacking</h3>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-xs text-gray-500 uppercase">Goals</label><input type="number" id="goals" value={perf.goals || 0} class="w-full border p-2 rounded" /></div>
          <div><label class="block text-xs text-gray-500 uppercase">Assists</label><input type="number" id="assists" value={perf.assists || 0} class="w-full border p-2 rounded" /></div>
          <div><label class="block text-xs text-gray-500 uppercase">Shots</label><input type="number" id="shots" value={perf.shots || 0} class="w-full border p-2 rounded" /></div>
          <div><label class="block text-xs text-gray-500 uppercase">Key Passes</label><input type="number" id="key_passes" value={perf.key_passes || 0} class="w-full border p-2 rounded" /></div>
        </div>
      </div>

      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
        <h3 class="font-bold mb-4 text-blue-600 border-b pb-2">Defensive</h3>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-xs text-gray-500 uppercase">Tackles</label><input type="number" id="tackles" value={perf.tackles || 0} class="w-full border p-2 rounded" /></div>
          <div><label class="block text-xs text-gray-500 uppercase">Interceptions</label><input type="number" id="interceptions" value={perf.interceptions || 0} class="w-full border p-2 rounded" /></div>
        </div>
      </div>

      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
        <h3 class="font-bold mb-4 text-blue-600 border-b pb-2">Physical</h3>
        <div><label class="block text-xs text-gray-500 uppercase">Minutes Played</label><input type="number" id="minutes" value={perf.minutes_played || 0} class="w-full border p-2 rounded" /></div>
      </div>

      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
        <h3 class="font-bold mb-4 text-blue-600 border-b pb-2">Ratings</h3>
        <div><label class="block text-xs text-gray-500 uppercase">Player Rating</label><input type="number" step="0.1" id="rating" value={perf.player_rating || 0} class="w-full border p-2 rounded" /></div>
      </div>

      <div class="col-span-2 flex justify-end gap-4 mt-2">
        <button type="button" onclick="history.back()" class="px-6 py-2 border rounded bg-white hover:bg-gray-100 font-bold">Cancel</button>
        <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 font-bold">Update Performance</button>
      </div>
    </form>
  </div>

  <script define:vars={{ id }}>
    document.getElementById('editForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = {
        goals: parseInt(document.getElementById('goals').value),
        assists: parseInt(document.getElementById('assists').value),
        shots: parseInt(document.getElementById('shots').value),
        minutes_played: parseInt(document.getElementById('minutes').value),
        player_rating: parseFloat(document.getElementById('rating').value)
      };

      try {
        const res = await fetch(`http://localhost:3001/api/performance/performance/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (res.ok) {
          alert('Update successful!');
          window.location.href = '/';
        } else {
          alert('Update failed');
        }
      } catch (err) {
        alert('Server error');
      }
    });
  </script>
</Layout>