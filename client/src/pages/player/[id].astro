---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const { id } = Astro.params;

let player: any = null;
try {
  const response = await fetch(`http://localhost:3001/api/performance/player/${id}`);
  player = await response.json();
} catch (error) {
  console.error("Error fetching player:", error);
}
---

<Layout>
  <div class="max-w-2xl">
    <h1 class="text-3xl font-bold mb-6">Edit Player: {player?.player_name}</h1>
    
    <form id="editForm" class="bg-white p-6 rounded-lg shadow space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Player Name</label>
        <input type="text" id="name" value={player?.player_name} class="w-full border p-2 rounded" required />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Team</label>
        <input type="text" id="team" value={player?.team} class="w-full border p-2 rounded" required />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Position</label>
        <input type="text" id="position" value={player?.position} class="w-full border p-2 rounded" required />
      </div>
      
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">
        Update Player
      </button>
    </form>
  </div>

  <script define:vars={{ id }}>
    document.getElementById('editForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const res = await fetch(`http://localhost:3001/api/performance/player/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          player_name: document.getElementById('name').value,
          team: document.getElementById('team').value,
          position: document.getElementById('position').value
        })
      });

      if (res.ok) {
        alert('Updated successfully!');
        window.location.href = '/';
      } else {
        alert('Update failed');
      }
    });
  </script>
</Layout>