---
const pathname = Astro.url.pathname;
---
<div class="flex min-h-screen bg-sky-50">
  <!-- 사이드바: 흰색 바탕 + 회색 글씨 -->
  <aside class="w-64 bg-white p-6 border-r border-sky-100">
    <h2 class="text-xl font-bold mb-8 text-sky-900">World Cup 2026</h2>
    <nav class="space-y-2">
      <a 
        href="/" 
        class={`block p-3 rounded-lg transition ${pathname === '/' ? 'bg-sky-200 text-sky-900 font-semibold' : 'text-slate-500 hover:text-sky-700 hover:bg-sky-50'}`}
      >
        Performances
      </a>
      <a 
        href="/ranking" 
        class={`block p-3 rounded-lg transition ${pathname === '/ranking' ? 'bg-sky-200 text-sky-900 font-semibold' : 'text-slate-500 hover:text-sky-700 hover:bg-sky-50'}`}
      >
        Rankings
      </a>
    </nav>
  </aside>

  <!-- 메인 영역 -->
  <main class="flex-1 p-8">
    <slot />
  </main>
</div>